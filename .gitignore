# Ignore everything by default.
# That means local docs/, output_logs/, requirements.txt, editor files,
# and generated assets stay out of the GitHub repo unless explicitly allowed below.
*

# Keep the git configuration for the repo itself.
!/.gitignore

# Keep the main repository readme.
!/README.md

# Keep the root SQL*Plus wrapper.
!/run_sqlplus_all.sql

# Keep the core Oracle project scripts.
!/sql/
!/sql/**
/sql/10_live_screenshot_queries.sql

# Keep one publishable ER diagram for the GitHub README.
!/docs/
/docs/**
!/docs/er_diagram_live.png
